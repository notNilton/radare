DB_HOST=localhost
DB_PORT=5432
DB_USER=radare
DB_PASSWORD=radare
DB_NAME=radare
DB_SSLMODE=disable
JWT_SECRET=change-me
PORT=8080
VITE_API_URL=http://localhost:8080/api

# LogDB — separate Postgres for audit logs and reconciliation snapshots.
# Leave empty in local dev to alias LogDB to the main DB (safe fallback).
# In production: postgresql://user:pass@logdb-host:5432/radare_logs?sslmode=disable
LOG_DB_URL=
LOG_DB_NAME=radare_logs

REDIS_URL=redis://localhost:6379/0
